---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const essays = await getCollection('essays');
  const months = new Set(essays.map((essay) => essay.id.split('/')[0]));

  return [...months].map((month) => ({
    params: { month },
  }));
}

const { month } = Astro.params;
const essays = await getCollection('essays');
const monthEssays = essays
  .filter((essay) => essay.id.startsWith(`${month}/`))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout title={`${month} | Tom's Lab`}>
  <section class="hero">
    <p class="eyebrow">Essays by month</p>
    <h1>{month}</h1>
  </section>

  <section class="essay-list">
    <h2>Essays</h2>

    {monthEssays.map((essay) => (
      <a class="essay-card" href={`/essays/${essay.id}`}>
        <span class="essay-date">{essay.data.date.toISOString().slice(0, 10)}</span>
        <span class="essay-title">{essay.data.title}</span>
      </a>
    ))}
  </section>
</Layout>
